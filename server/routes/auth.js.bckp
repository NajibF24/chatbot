// server/routes/auth.js
import express from 'express';
import bcrypt from 'bcryptjs';
import User from '../models/User.js';
import Bot from '../models/Bot.js';
import LDAPService from '../services/ldap.service.js';
import { requireAuth } from '../middleware/auth.js';

const router = express.Router();
const ldapService = new LDAPService();

// ==================== DUAL LOGIN SYSTEM ====================
router.post('/login', async (req, res) => {
  try {
    console.log('='.repeat(70));
    console.log('🔐 LOGIN ATTEMPT');
    
    const { username, password } = req.body;

    if (!username || !password) {
      return res.status(400).json({ error: 'Username and password required' });
    }

    // ==================== SKENARIO 1: LDAP USER (Cek Grup MIS) ====================
    if (ldapService.isEnabled()) {
      console.log('🔐 STEP 1: Checking LDAP/Active Directory');

      try {
        const ldapResult = await ldapService.authenticate(username, password);

        if (ldapResult.success) {
          console.log('✅ LDAP Authentication SUCCESSFUL');
          
          const userGroups = ldapResult.user.groups || [];
          console.log(`   User Groups: ${userGroups.join(', ')}`);

          // --- LOGIC PENENTUAN HAK AKSES (ROOT vs USER) ---
          
          // 1. Cek apakah SALAH SATU grup user mengandung kata "MIS"
          // .some() akan return TRUE jika minimal satu grup cocok
          const isMIS = userGroups.some(group => 
            group.toLowerCase().includes('mis')
          );

          // 2. Tentukan status Admin/Root
          // User jadi admin jika dia anggota MIS ATAU didefinisikan di env LDAP_ADMIN_GROUPS
          const isRootAccess = isMIS || ldapService.isAdmin(userGroups);

          console.log(`   Is MIS Member: ${isMIS ? 'YES' : 'NO'}`);
          console.log(`   Granting Root Access: ${isRootAccess ? 'YES (Dashboard + All Bots)' : 'NO'}`);

          // 3. Tentukan Bot yang didapat
          let botsToAssign = [];
          
          if (isRootAccess) {
            // JIKA ROOT (MIS): Dapat SEMUA bot
            botsToAssign = await Bot.find({});
          } else {
            // JIKA BUKAN ROOT: Hanya dapat bot ChatGPT
            botsToAssign = await Bot.find({ name: { $regex: /chatgpt/i } });
            
            // Fallback: Jika bot ChatGPT belum dibuat, kasih bot apa saja yg ada (biar tidak error)
            if (botsToAssign.length === 0) {
              const anyBot = await Bot.findOne();
              if (anyBot) botsToAssign = [anyBot];
            }
          }

          // 4. Update atau Buat User di Database Lokal
          let user = await User.findOne({ username: ldapResult.user.username });

          if (!user) {
            console.log('🆕 Creating new user from LDAP');
            user = new User({
              username: ldapResult.user.username,
              password: await bcrypt.hash(Math.random().toString(36), 10), // Password dummy
              isAdmin: isRootAccess, // ✅ Set flag admin untuk akses Dashboard
              assignedBots: botsToAssign.map(b => b._id),
              email: ldapResult.user.email,
              displayName: ldapResult.user.displayName,
              department: ldapResult.user.department,
              authMethod: 'ldap',
              lastLogin: new Date()
            });
          } else {
            // Update user existing (Sinkronisasi Hak Akses)
            // Ini penting: Jika user dikeluarkan dari grup MIS di AD, login berikutnya akses root dia HILANG.
            user.isAdmin = isRootAccess; 
            user.assignedBots = botsToAssign.map(b => b._id);
            user.authMethod = 'ldap';
            user.lastLogin = new Date();
            
            // Update info profil
            if (ldapResult.user.displayName) user.displayName = ldapResult.user.displayName;
            if (ldapResult.user.email) user.email = ldapResult.user.email;
          }

          await user.save();
          await user.populate('assignedBots');

          // 5. Buat Session
          req.session.userId = user._id;
          req.session.isAdmin = user.isAdmin; // Session menyimpan status admin
          req.session.authMethod = 'ldap';

          return res.json({
            user: {
              id: user._id,
              username: user.username,
              displayName: ldapResult.user.displayName,
              isAdmin: user.isAdmin, // Frontend akan menggunakan ini untuk menampilkan menu Admin Dashboard
              assignedBots: user.assignedBots,
              authMethod: 'ldap'
            }
          });
        }
      } catch (ldapError) {
        console.error('❌ LDAP Error (Continuing to local):', ldapError.message);
      }
    }

    // ==================== SKENARIO 2: LOCAL ADMIN (FALLBACK) ====================
    // Ini menangani login user 'admin' yang dibuat di seedUpdated.js
    console.log('🔐 STEP 2: Checking Local Database');
    
    const user = await User.findOne({ username }).populate('assignedBots');

    // Cek password lokal
    if (!user || !(await bcrypt.compare(password, user.password))) {
      return res.status(401).json({ error: 'Invalid credentials' });
    }

    console.log(`✅ Local Login Successful: ${user.username}`);
    console.log(`   Is Admin: ${user.isAdmin}`);

    // Update session
    req.session.userId = user._id;
    req.session.isAdmin = user.isAdmin;
    req.session.authMethod = 'local';
    
    user.lastLogin = new Date();
    await user.save();

    res.json({
      user: {
        id: user._id,
        username: user.username,
        displayName: user.displayName,
        isAdmin: user.isAdmin,
        assignedBots: user.assignedBots,
        authMethod: 'local'
      }
    });

  } catch (error) {
    console.error('Login Error:', error);
    res.status(500).json({ error: error.message });
  }
});

// Routes logout, me, test-ldap (tetap sama)
router.post('/logout', (req, res) => {
  req.session.destroy();
  res.json({ message: 'Logged out successfully' });
});

router.get('/me', requireAuth, async (req, res) => {
  const user = await User.findById(req.session.userId).populate('assignedBots').select('-password');
  res.json({ user });
});

router.get('/test-ldap', requireAuth, async (req, res) => {
  if (!ldapService.isEnabled()) return res.json({ enabled: false });
  try {
    const result = await ldapService.testConnection();
    res.json({ enabled: true, ...result });
  } catch (err) {
    res.status(500).json({ error: err.message });
  }
});

export default router;
